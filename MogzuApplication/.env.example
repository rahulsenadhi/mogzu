# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay (India payments)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here_never_expose_in_frontend

# Resend (transactional email)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@mogzu.com

# N8N (automation)
VITE_N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.app.n8n.cloud
N8N_WEBHOOK_SECRET=your_webhook_secret_here
# Edge function: POST .../drain-notification-emails (set on Supabase function secrets)
CRON_SECRET=your_cron_secret_here

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# White-label: force a partner theme locally (else resolved from subdomain). e.g. acme
VITE_WHITE_LABEL_SLUG=
